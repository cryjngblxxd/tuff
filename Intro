local function Tween(inst, dur, props, style, dir)
    style = style or Enum.EasingStyle.Quint
    dir = dir or Enum.EasingDirection.Out
    local t = TweenService:Create(inst, TweenInfo.new(dur, style, dir), props)
    t:Play()
    return t
end

