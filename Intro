local elapsed = 0
local conn
local baseSize = 140
local progress = 0

local function StartIntro()
    Tween(Bg, 0.5, { BackgroundTransparency = 0 }, Enum.EasingStyle.Sine)
    Tween(Blur, 0.6, { Size = 24 }, Enum.EasingStyle.Sine)
    Tween(CC, 0.5, { Brightness = -0.05, Contrast = 0.15 })
    
    particlesActive = true
    spawn(function()
        while particlesActive do
            CreateParticle()
            wait(math.random(8, 18) / 100)
        end
    end)
    
    wait(0.6)
    
    Tween(Ring3, 0.5, { Size = UDim2.new(0, 300, 0, 300) }, Enum.EasingStyle.Back)
    Tween(Stroke3, 0.4, { Transparency = 0.5 })
    
    wait(0.08)
    
    Tween(GlowRing, 0.5, { Size = UDim2.new(0, 280, 0, 280) }, Enum.EasingStyle.Back)
    Tween(GlowStroke, 0.45, { Transparency = 0.8 })
    Tween(Ring1, 0.45, { Size = UDim2.new(0, 260, 0, 260) }, Enum.EasingStyle.Back)
    Tween(Stroke1, 0.4, { Transparency = 0.15 })
    
    wait(0.08)
    
    Tween(Ring2, 0.45, { Size = UDim2.new(0, 220, 0, 220) }, Enum.EasingStyle.Back)
    Tween(Stroke2, 0.4, { Transparency = 0.25 })
    
    for i, arc in ipairs(Arcs) do
        spawn(function()
            wait(i * 0.05)
            Tween(arc.Stroke, 0.4, { Transparency = 0.15 })
        end)
    end
    
    wait(0.74)
    
    Tween(Bloom, 0.15, { Intensity = 0.8 })
    Tween(CC, 0.1, { Brightness = 0.2 })
    
    Tween(LogoGlow3, 0.5, {
        Size = UDim2.new(0, baseSize * 1.6, 0, baseSize * 1.6),
        ImageTransparency = 0.8
    }, Enum.EasingStyle.Back)
    
    wait(0.04)
    Tween(LogoGlow2, 0.45, {
        Size = UDim2.new(0, baseSize * 1.35, 0, baseSize * 1.35),
        ImageTransparency = 0.6
    }, Enum.EasingStyle.Back)
    
    wait(0.04)
    Tween(LogoGlow1, 0.4, {
        Size = UDim2.new(0, baseSize * 1.15, 0, baseSize * 1.15),
        ImageTransparency = 0.4
    }, Enum.EasingStyle.Back)
    
    wait(0.04)
    Tween(Logo, 0.4, {
        Size = UDim2.new(0, baseSize, 0, baseSize),
        ImageTransparency = 0
    }, Enum.EasingStyle.Back)
    
    Tween(CC, 0.35, { Brightness = -0.05 })
    Tween(Bloom, 0.45, { Intensity = 0.3 })
    
    wait(0.68)
    
    Tween(TitleMain, 0.3, { TextTransparency = 0 })
    Tween(TitleGlow, 0.3, { Thickness = 1.5, Transparency = 0.5 })
    
    wait(0.06)
    Tween(TitleAccent, 0.3, { TextTransparency = 0 })
    Tween(AccentGlow, 0.3, { Thickness = 1, Transparency = 0.6 })
    
    wait(0.1)
    Tween(Sub, 0.25, { TextTransparency = 0.2 })
    
    wait(0.1)
    Tween(LoadBar, 0.2, { BackgroundTransparency = 0.5 })
    Tween(LoadFill, 0.15, { BackgroundTransparency = 0 })
    Tween(Percent, 0.2, { TextTransparency = 0.2 })
    
    conn = RunService.RenderStepped:Connect(function(dt)
        elapsed = elapsed + dt
        
        for _, arc in ipairs(Arcs) do
            arc.Gradient.Rotation = (arc.Gradient.Rotation + arc.Speed * arc.Direction * dt) % 360
        end
        
        local pulse = 1 + math.sin(elapsed * 2) * 0.015
        Ring1.Size = UDim2.new(0, 260 * pulse, 0, 260 * pulse)
        Ring2.Size = UDim2.new(0, 220 * pulse, 0, 220 * pulse)
        Ring3.Size = UDim2.new(0, 300 * pulse, 0, 300 * pulse)
        GlowRing.Size = UDim2.new(0, 280 * pulse, 0, 280 * pulse)
        
        local b = 1 + math.sin(elapsed * 1.5) * 0.015
        local ls = baseSize * b
        Logo.Size = UDim2.new(0, ls, 0, ls)
        LogoGlow1.Size = UDim2.new(0, ls * 1.15, 0, ls * 1.15)
        LogoGlow2.Size = UDim2.new(0, ls * 1.35, 0, ls * 1.35)
        LogoGlow3.Size = UDim2.new(0, ls * 1.6, 0, ls * 1.6)
        
        LogoGlow1.ImageTransparency = 0.4 + math.sin(elapsed * 2.5) * 0.08
        LogoGlow2.ImageTransparency = 0.6 + math.sin(elapsed * 2.5 + 0.5) * 0.08
        LogoGlow3.ImageTransparency = 0.8 + math.sin(elapsed * 2.5 + 1) * 0.05
        
        GlowStroke.Transparency = 0.7 + math.sin(elapsed * 3) * 0.15
        LoadGrad.Offset = Vector2.new(math.sin(elapsed * 3) * 0.15, 0)
        BgGrad.Rotation = 135 + math.sin(elapsed * 0.3) * 10
    end)
    
    local loadTime = 2.5
    local startT = tick()
    
    while progress < 1 do
        local e = tick() - startT
        progress = math.min(e / loadTime, 1)
        local eased = 1 - math.pow(1 - progress, 3)
        
        LoadFill.Size = UDim2.new(eased, 0, 1, 0)
        Percent.Text = math.floor(eased * 100) .. "%"
        wait()
    end
    
    wait(0.1)
    
    Sub.Text = Config.CompletedText
    Tween(Sub, 0.2, { TextColor3 = Config.White, TextTransparency = 0 })
    Tween(Percent, 0.2, { TextColor3 = Config.Primary })
    
    Tween(Bloom, 0.08, { Intensity = 0.6 })
    Tween(CC, 0.08, { Brightness = 0.1 })
    wait(0.1)
    Tween(Bloom, 0.2, { Intensity = 0.3 })
    Tween(CC, 0.15, { Brightness = -0.05 })
    
    wait(0.2)
    
    particlesActive = false
    
    if IntroSound then
        local startVol = IntroSound.Volume
        spawn(function()
            local fadeT = tick()
            local fadeDur = 0.5
            while tick() - fadeT < fadeDur do
                if IntroSound then
                    IntroSound.Volume = startVol * (1 - ((tick() - fadeT) / fadeDur))
                end
                wait()
            end
            if IntroSound then
                IntroSound:Stop()
                IntroSound:Destroy()
                IntroSound = nil
            end
        end)
    end
    
    local fadeTime = 0.4
    
    Tween(Logo, fadeTime, { ImageTransparency = 1 })
    Tween(LogoGlow1, fadeTime, { ImageTransparency = 1 })
    Tween(LogoGlow2, fadeTime, { ImageTransparency = 1 })
    Tween(LogoGlow3, fadeTime, { ImageTransparency = 1 })
    
    Tween(Stroke1, fadeTime, { Transparency = 1 })
    Tween(Stroke2, fadeTime, { Transparency = 1 })
    Tween(Stroke3, fadeTime, { Transparency = 1 })
    Tween(GlowStroke, fadeTime, { Transparency = 1 })
    
    for _, arc in ipairs(Arcs) do
        Tween(arc.Stroke, fadeTime, { Transparency = 1 })
    end
    
    Tween(TitleMain, 0.3, { TextTransparency = 1 })
    Tween(TitleAccent, 0.3, { TextTransparency = 1 })
    Tween(TitleGlow, 0.3, { Transparency = 1 })
    Tween(AccentGlow, 0.3, { Transparency = 1 })
    Tween(Sub, 0.3, { TextTransparency = 1 })
    Tween(LoadBar, 0.3, { BackgroundTransparency = 1 })
    Tween(LoadFill, 0.3, { BackgroundTransparency = 1 })
    Tween(Percent, 0.3, { TextTransparency = 1 })
    
    wait(0.2)
    
    if conn then conn:Disconnect() end
    
    Tween(Bg, 0.4, { BackgroundTransparency = 1 })
    Tween(Blur, 0.4, { Size = 0 })
    Tween(Bloom, 0.4, { Intensity = 0 })
    Tween(CC, 0.4, { Brightness = 0, Contrast = 0, Saturation = 0 })
    
    wait(0.4)
    
    if IntroSound then
        pcall(function()
            IntroSound:Stop()
            IntroSound:Destroy()
        end)
        IntroSound = nil
    end
    
    Gui:Destroy()
    Blur:Destroy()
    CC:Destroy()
    Bloom:Destroy()
end

spawn(StartIntro)
