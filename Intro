local IntroSound = nil
do
    local fileName = "AvenirIntro2.mp3"
    local fileId = "1liOwkz1ph9tO9E133bdI3MN_yMdj3qq5"
    
    local function isValidMp3(data)
        if not data or #data < 1000 then return false end
        if data:sub(1, 100):lower():find("<!doctype") or data:sub(1, 100):lower():find("<html") then
            return false
        end
        return true
    end
    
    local function tryDownload()
        local urls = {
            "https://drive.usercontent.google.com/download?id=" .. fileId .. "&export=download&confirm=t",
            "https://drive.google.com/uc?export=download&confirm=t&id=" .. fileId,
            "https://docs.google.com/uc?export=download&id=" .. fileId,
        }
        for i, url in ipairs(urls) do
            local success, data = pcall(function() return game:HttpGet(url) end)
            if success and data and isValidMp3(data) then
                return data
            end
        end
        return nil
    end
    
    if isfile(fileName) then
        local existing = readfile(fileName)
        if not isValidMp3(existing) then
            pcall(function() delfile(fileName) end)
        end
    end
    
    if not isfile(fileName) then
        local data = tryDownload()
        if data then
            pcall(function() writefile(fileName, data) end)
        end
    end
    
    if isfile(fileName) then
        local soundId
        local ok = pcall(function() soundId = getcustomasset(fileName) end)
        if ok and soundId then
            IntroSound = Instance.new("Sound")
            IntroSound.SoundId = soundId
            IntroSound.Volume = 1
            IntroSound.Parent = game:GetService("SoundService")
            IntroSound:Play()
        end
    end
end

